<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
           xsi:type="MailApp">
  <Id>3f9b68c4-3a5d-4d2c-95a6-2d8c6f32a0b1</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>IT Task Reminder</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="IT Task Reminder"/>
  <Description DefaultValue="Outlook add-in to view IT task reminders and download calendar invites."/>
  <IconUrl DefaultValue="https://localhost:3000/favicon.ico"/>
  <SupportUrl DefaultValue="https://localhost:3000"/>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.1"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3000/outlook-addin"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" Version="1.0">
    <Hosts>
      <Host Name="Mailbox">
        <DesktopFormFactor>
          <FunctionFile resid="functionFile"/>
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="groupLabel"/>
                <Control xsi:type="Button" id="showTaskReminderPane">
                  <Label resid="paneButtonLabel"/>
                  <Supertip>
                    <Title resid="paneButtonLabel"/>
                    <Description resid="paneButtonDescription"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="icon16"/>
                    <bt:Image size="32" resid="icon32"/>
                    <bt:Image size="80" resid="icon80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskPane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="taskPaneUrl"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
          <TaskPane id="ButtonId1">
            <SourceLocation resid="taskPaneUrl"/>
          </TaskPane>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="icon16" DefaultValue="https://localhost:3000/favicon.ico"/>
        <bt:Image id="icon32" DefaultValue="https://localhost:3000/favicon.ico"/>
        <bt:Image id="icon80" DefaultValue="https://localhost:3000/favicon.ico"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="functionFile" DefaultValue="https://localhost:3000/outlook-addin"/>
        <bt:Url id="taskPaneUrl" DefaultValue="https://localhost:3000/outlook-addin"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="groupLabel" DefaultValue="IT Task Reminder"/>
        <bt:String id="paneButtonLabel" DefaultValue="Task Reminders"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="paneButtonDescription" DefaultValue="Open the IT Task Reminder pane to view tasks and calendar reminders."/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
